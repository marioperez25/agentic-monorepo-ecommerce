# Copy this to `.env` (which is gitignored) and fill in real values.

# SQLAlchemy async URL. Matches the docker-compose service defaults.
DATABASE_URL=postgresql+asyncpg://agentic_ecommerce:agentic_ecommerce@localhost:5432/agentic_ecommerce

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-to-a-long-random-string

# Optional — defaults shown:
# JWT_ALGORITHM=HS256
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
